# ============================================================================
# KAIZEN — Environment Configuration
# ============================================================================

# Application
APP_NAME=KAIZEN
APP_VERSION=1.0.0
ENVIRONMENT=development
LOG_LEVEL=INFO

# Database (SQLite path relative to backend/)
DATABASE_PATH=data/governance.db

# CORS (comma-separated origins, or * for development)
CORS_ORIGINS=*

# OpenAI (optional — system works without this)
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini

# Risk Thresholds (0-100)
RISK_BLOCK_THRESHOLD=70.0
RISK_ESCALATE_THRESHOLD=40.0

# Score Weights (must sum to 1.0)
WEIGHT_RULES=0.4
WEIGHT_MEMORY=0.3
WEIGHT_ANOMALY=0.3

# Server
HOST=0.0.0.0
PORT=8000
